{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["vendor/**", "dist/**", "node_modules/**", "test/**"],
  "tabWidth": 2,
  "useTabs": false,
  "endOfLine": "lf",
  "printWidth": 120,
  "overrides": [
    {
      "files": ["**/*.{js,jsx,ts,tsx}"],
      "options": {
        "semi": false,
        "singleQuote": true,
        "trailingComma": "all",
        "bracketSpacing": true,
        "internalPattern": ["@/", "~/"],
        "sortImports": {
          "groups": ["type", "builtin", "external", "internal", ["parent", "sibling", "index"], "style", "unknown"]
        }
      }
    }
  ]
}
